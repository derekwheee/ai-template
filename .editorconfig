root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# JSON and YAML are conventionally 2 spaces and tools often regenerate them
[*.{json,yml,yaml}]
indent_size = 2

# XML-based .NET project files
[*.{csproj,props,targets,config}]
indent_size = 4
