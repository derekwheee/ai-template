{
    "servers": {
        "github": {
            "type": "stdio",
            "command": "github-mcp-server",
            "args": ["stdio"],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GH_TOKEN}"
            }
        },
        "sqlite": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@modelcontextprotocol/server-sqlite", "${workspaceFolder}/MyApp/MyApp.Api/app.db"]
        },
        "playwright": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@playwright/mcp"]
        },
        "shadcn": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "shadcn@latest", "mcp"]
        }
    }
}
